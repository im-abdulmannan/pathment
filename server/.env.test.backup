# Test environment variables
# Copy this file to .env.test and fill in real values for a test postgres DB

DATABASE_URL=postgres://postgres:user@localhost:5432/pathment_test
NODE_ENV=test

# JWT — short-lived tokens fine for tests
JWT_SECRET=pathment_test_jwt_secret_do_not_use_in_production
JWT_REFRESH_SECRET=pathment_test_refresh_secret_do_not_use_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Disable heavy boot-time side-effects in tests
GAMIFICATION_BOOTSTRAP_DISABLED=true
NOTIFICATION_SCHEDULER_DISABLED=true

# These must be set but are mocked in tests — dummy values are fine
RESEND_API_KEY=re_test_dummy
OPENAI_API_KEY=sk-test-dummy
GROQ_API_KEY=gsk_test_dummy
CLOUDINARY_CLOUD_NAME=test
CLOUDINARY_API_KEY=test
CLOUDINARY_API_SECRET=test

CLIENT_URL=http://localhost:3003

# Queue Configuration (for background jobs)
UPSTASH_REDIS_URL=rediss://default:gQAAAAAAAh1-AAIgcDIzNTEyMWNlM2Q5NmM0MWRhODM3OTY2ODIyNDU0Y2JkMg@epic-mantis-138622.upstash.io:6379